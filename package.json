{
  "name": "cashight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0205 next dev",
    "build": "NODE_OPTIONS=--disable-warning=DEP0205 next build",
    "verify:static": "node scripts/verify-static-export.mjs",
    "build:lambdas": "node scripts/build-lambdas.mjs",
    "start": "next start",
    "lint": "eslint",
    "cleanup:legacy-buckets": "tsx scripts/delete-legacy-s3-buckets.ts --confirm-delete-legacy-buckets",
    "cleanup:legacy-buckets:dry-run": "tsx scripts/delete-legacy-s3-buckets.ts --dry-run",
    "security:scan-logs": "tsx scripts/security-scan-logs.ts",
    "migrate:statements": "tsx scripts/migrate-statements.ts",
    "reconcile:statements": "tsx scripts/reconcile-statements.ts",
    "deploy:frontend": "node scripts/deploy-frontend.mjs",
    "release:manifest": "node scripts/create-release-manifest.mjs",
    "smoke:serverless": "node scripts/smoke-serverless.mjs",
    "test": "NODE_OPTIONS=--disable-warning=DEP0205 vitest run",
    "test:e2e": "playwright test",
    "test:e2e:current": "playwright test tests/e2e/current-production.spec.ts",
    "test:watch": "NODE_OPTIONS=--disable-warning=DEP0205 vitest"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@aws-lambda-powertools/metrics": "^2.33.1",
    "@aws-lambda-powertools/tracer": "^2.33.1",
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@aws-sdk/client-ssm": "^3.1055.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@cashight/domain": "workspace:*",
    "@google/genai": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "oidc-client-ts": "^3.5.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "6.0.227",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.2.2"
}
