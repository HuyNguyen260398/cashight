GEMINI_API_KEY=
STATEMENTS_BUCKET=
AWS_REGION=ap-southeast-1
# PDF_PASSWORD: password to unlock password-protected TPBank statement PDFs.
# Set the real value in .env.local (dev) and the Amplify Console (prod).
# This is server-only — never exposed to the client, logs, or Gemini/S3 payloads.
PDF_PASSWORD=

# Auth.js (Google) — single-user access control
# Real values go only in .env.local (dev) and the Amplify Console (prod), never committed.
# Generate AUTH_SECRET with: npx auth secret  (or: openssl rand -base64 32)
# ALLOWED_EMAIL: the single Google account permitted to sign in.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ALLOWED_EMAIL=

# AWS Cognito (second login option) — from `terraform output` (Step 18)
# Same single-user gate: a Cognito login must also resolve to ALLOWED_EMAIL.
# AUTH_COGNITO_ID     = terraform output cognito_user_pool_client_id
# AUTH_COGNITO_SECRET = terraform output -raw cognito_user_pool_client_secret
# AUTH_COGNITO_ISSUER = terraform output cognito_issuer
#   (e.g. https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_XXXXXXXXX)
AUTH_COGNITO_ID=
AUTH_COGNITO_SECRET=
AUTH_COGNITO_ISSUER=
