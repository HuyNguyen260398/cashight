# ── Serverless backend (Lambda / scripts) ────────────────────────────────────
# Set in .env.local for local script use. Production values are in AWS Secrets
# Manager; Lambda env vars come from Terraform outputs.

# S3 bucket for parsed statement JSON objects (from: terraform output statements_bucket_name)
STATEMENTS_BUCKET=

# AWS region for all resources
STORAGE_REGION=ap-southeast-1
AWS_REGION=ap-southeast-1

# Single email address permitted to sign in (also set as terraform var allowed_email)
ALLOWED_EMAIL=

# ── Frontend SPA (build-time public config) ───────────────────────────────────
# These NEXT_PUBLIC_ values are baked into the static export at build time.
# Set matching values in the CI environment before running `pnpm build`.

# API Gateway base URL (from: terraform output api_gateway_base_url)
NEXT_PUBLIC_API_BASE_URL=https://api.cashight.nghuy.link

# Cognito OIDC issuer URL (from: terraform output cognito_issuer)
NEXT_PUBLIC_COGNITO_AUTHORITY=https://cognito-idp.ap-southeast-1.amazonaws.com/<user-pool-id>

# Cognito public SPA client ID — no secret (from: terraform output cognito_spa_client_id)
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# Production app origin (used for PKCE redirect URI validation)
NEXT_PUBLIC_APP_ORIGIN=https://cashight.nghuy.link

# ── Local Lambda development (optional) ──────────────────────────────────────
# Only needed when running Lambda handlers locally. Not used in the static build.
# In production these live in Secrets Manager; Lambda reads them at runtime.

# GEMINI_API_KEY=
# PDF_PASSWORD=
