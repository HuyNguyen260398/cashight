  visibility_config {
    cloudwatch_metrics_enabled = true
    metric_name                = "${var.project_name}-api-waf"
    sampled_requests_enabled   = true
  }

  tags = {
    Project = var.project_name
    Purpose = "WAF protection for API Gateway"
  }
}
